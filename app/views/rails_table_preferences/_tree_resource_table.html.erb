<% unless defined?(TreeView::Tree) %>
  <% raise "tree_resource_table_for requires the tree_view gem" %>
<% end %>

<% tree = TreeView::Tree.new(records: records, parent_id_method: parent_id_method) %>
<% ui_config = TreeView::UiConfigBuilder.new(context: self, node_prefix: table_key).build_static %>
<% render_state = TreeView::RenderState.new(
  tree: tree,
  root_items: tree.root_items,
  row_partial: "rails_table_preferences/tree_resource_table_row",
  ui_config: ui_config,
  row_locals: { table_state: table_state }
) %>

<% render_editor = options.fetch(:render_editor, true) %>
<% if render_editor %>
  <%= table_preferences_editor(
    table_key: table_key,
    name: name,
    settings: settings,
    columns: columns
  ) %>
<% end %>

<% caption = local_assigns.fetch(:caption, nil) %>
<% table_options = options.except(:class, :render_editor).merge(
  class: ["tree-view-table", "rails-table-preferences-tree-resource-table", options[:class]].compact.join(" ")
) %>
<% visible_columns = table_state.fetch("visible_columns") %>

<%= table_preferences_table_tag(
  table_key: table_key,
  name: name,
  settings: settings,
  columns: columns,
  **table_options
) do %>
  <% if caption.present? %>
    <caption><%= caption %></caption>
  <% end %>
  <thead>
    <tr>
      <% visible_columns.each do |column| %>
        <th data-rails-table-preferences-column-key="<%= column.fetch("key") %>">
          <%= column["label"] || column.fetch("key") %>
        </th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% if records.empty? %>
      <tr class="rails-table-preferences-resource-table__empty-row">
        <td class="rails-table-preferences-resource-table__empty-cell" colspan="<%= visible_columns.size %>">
          <%= I18n.t("rails_table_preferences.resource_table.empty", default: "No records to display") %>
        </td>
      </tr>
    <% else %>
      <%= tree_view_rows(render_state) %>
    <% end %>
  </tbody>
<% end %>
