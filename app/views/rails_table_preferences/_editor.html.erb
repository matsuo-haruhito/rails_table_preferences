<% editor_instance_key = local_assigns[:editor_instance_key].presence || SecureRandom.hex(4) %>
<% editor_id_key = [table_key, name, editor_instance_key].compact.map { |value| value.to_s.parameterize(separator: "-") }.reject(&:blank?).join("-") %>
<% editor_id_key = "editor" if editor_id_key.blank? %>
<% editor_id_prefix = "rails-table-preferences-#{editor_id_key}" %>
<% preset_select_id = "#{editor_id_prefix}-preset-select" %>
<% preset_name_id = "#{editor_id_prefix}-preset-name" %>
<% preset_hint_id = "#{editor_id_prefix}-preset-hint" %>
<% default_preset_hint_id = "#{editor_id_prefix}-default-preset-hint" %>
<% action_hint_id = "#{editor_id_prefix}-action-hint" %>
<% delete_label = t("rails_table_preferences.editor.delete", default: "削除") %>
<% delete_confirm_label = t("rails_table_preferences.editor.delete_confirm", default: "この保存済み設定を削除します。よろしいですか？") %>
<% reset_label = t("rails_table_preferences.editor.reset", default: "初期状態に戻す") %>
<% reset_hint = t("rails_table_preferences.editor.reset_hint", default: "保存前の表示設定の変更を破棄して、初期状態に戻します。") %>
<% preset_scope_owner_label = t("rails_table_preferences.editor.scope_owner", default: "個人") %>
<% preset_target_context = t("rails_table_preferences.editor.preset_target_context", default: "読み込む保存済み設定を選択") %>
<% preset_name_context = t("rails_table_preferences.editor.preset_name_context", default: "保存または別名保存で使う設定名を入力") %>
<% preset_relationship_hint = t("rails_table_preferences.editor.preset_relationship_hint", default: "保存済み設定は読み込む対象、設定名は保存または別名保存で使う名前です。") %>
<% default_preset_hint = t("rails_table_preferences.editor.default_preset_hint", default: "保存または別名保存すると、この設定を標準設定として登録します。") %>
<% read_only_preset_hint = t("rails_table_preferences.editor.read_only_preset_hint", default: "この設定は直接上書きできません。保存すると個人用設定として作成または更新されます。") %>
<% action_hint = t("rails_table_preferences.editor.action_hint", default: "適用は現在の表示に反映し、保存は現在の設定名に保存、別名で保存は新しい設定名として保存します。") %>
<% apply_context = t("rails_table_preferences.editor.apply_context", default: "現在の表示に反映") %>
<% save_context = t("rails_table_preferences.editor.save_context", default: "現在の設定名に保存") %>
<% save_as_new_context = t("rails_table_preferences.editor.save_as_new_context", default: "新しい設定名として保存") %>
<% status_region_label = t("rails_table_preferences.editor.status_region", default: "保存状態") %>

<div data-controller="rails-table-preferences"
     data-rails-table-preferences-table-key-value="<%= table_key %>"
     data-rails-table-preferences-name-value="<%= name %>"
     data-rails-table-preferences-url-value="<%= preference_url %>"
     data-rails-table-preferences-collection-url-value="<%= collection_url %>"
     data-rails-table-preferences-settings-value="<%= settings_json %>"
     data-rails-table-preferences-columns-value="<%= columns_json %>"
     data-rails-table-preferences-order-label-value="<%= t("rails_table_preferences.editor.order", default: "表示順") %>"
     data-rails-table-preferences-width-label-value="<%= t("rails_table_preferences.editor.width", default: "列幅") %>"
     data-rails-table-preferences-truncate-label-value="<%= t("rails_table_preferences.editor.truncate", default: "省略文字数") %>"
     data-rails-table-preferences-drag-label-value="<%= t("rails_table_preferences.editor.drag_to_reorder", default: "ドラッグして並び替え") %>"
     data-rails-table-preferences-resize-label-value="<%= t("rails_table_preferences.editor.resize_column", default: "列幅を変更") %>"
     data-rails-table-preferences-filter-label-value="<%= t("rails_table_preferences.editor.filter", default: "絞り込み") %>"
     data-rails-table-preferences-filter-apply-label-value="<%= t("rails_table_preferences.editor.apply", default: "適用") %>"
     data-rails-table-preferences-filter-clear-label-value="<%= t("rails_table_preferences.editor.filter_clear", default: "クリア") %>"
     data-rails-table-preferences-filter-operator-label-value="<%= t("rails_table_preferences.editor.filter_operator", default: "条件") %>"
     data-rails-table-preferences-filter-value-label-value="<%= t("rails_table_preferences.editor.filter_value", default: "値") %>"
     data-rails-table-preferences-filter-from-label-value="<%= t("rails_table_preferences.editor.filter_from", default: "開始") %>"
     data-rails-table-preferences-filter-to-label-value="<%= t("rails_table_preferences.editor.filter_to", default: "終了") %>"
     data-rails-table-preferences-sort-asc-label-value="<%= t("rails_table_preferences.editor.sort_asc", default: "昇順") %>"
     data-rails-table-preferences-sort-desc-label-value="<%= t("rails_table_preferences.editor.sort_desc", default: "降順") %>"
     data-rails-table-preferences-sort-clear-label-value="<%= t("rails_table_preferences.editor.sort_clear", default: "並び替え解除") %>"
     data-rails-table-preferences-delete-confirm-label-value="<%= delete_confirm_label %>"
     data-rails-table-preferences-read-only-preset-hint-label-value="<%= read_only_preset_hint %>"
     data-rails-table-preferences-scope-owner-label-value="<%= preset_scope_owner_label %>"
     data-rails-table-preferences-scope-shared-label-value="<%= t("rails_table_preferences.editor.scope_shared", default: "共有") %>"
     data-rails-table-preferences-scope-role-label-value="<%= t("rails_table_preferences.editor.scope_role", default: "ロール") %>"
     data-rails-table-preferences-scope-organization-label-value="<%= t("rails_table_preferences.editor.scope_organization", default: "組織") %>"
     data-rails-table-preferences-loading-status-label-value="<%= t("rails_table_preferences.editor.loading_status", default: "設定を読み込み中です...") %>"
     data-rails-table-preferences-loaded-status-label-value="<%= t("rails_table_preferences.editor.loaded_status", default: "設定を読み込みました。") %>"
     data-rails-table-preferences-loading-failed-status-label-value="<%= t("rails_table_preferences.editor.loading_failed_status", default: "設定の読み込みを完了できませんでした。") %>"
     data-rails-table-preferences-saving-status-label-value="<%= t("rails_table_preferences.editor.saving_status", default: "設定を保存中です...") %>"
     data-rails-table-preferences-saved-status-label-value="<%= t("rails_table_preferences.editor.saved_status", default: "設定を保存しました。") %>"
     data-rails-table-preferences-saving-failed-status-label-value="<%= t("rails_table_preferences.editor.saving_failed_status", default: "設定の保存を完了できませんでした。") %>"
     data-rails-table-preferences-saving-as-new-status-label-value="<%= t("rails_table_preferences.editor.saving_as_new_status", default: "新しい設定を保存中です...") %>"
     data-rails-table-preferences-saved-as-new-status-label-value="<%= t("rails_table_preferences.editor.saved_as_new_status", default: "新しい設定を保存しました。") %>"
     data-rails-table-preferences-saving-as-new-failed-status-label-value="<%= t("rails_table_preferences.editor.saving_as_new_failed_status", default: "新しい設定の保存を完了できませんでした。") %>"
     data-rails-table-preferences-deleting-status-label-value="<%= t("rails_table_preferences.editor.deleting_status", default: "設定を削除中です...") %>"
     data-rails-table-preferences-deleted-status-label-value="<%= t("rails_table_preferences.editor.deleted_status", default: "設定を削除しました。") %>"
     data-rails-table-preferences-deleting-failed-status-label-value="<%= t("rails_table_preferences.editor.deleting_failed_status", default: "設定の削除を完了できませんでした。") %>"
     data-rails-table-preferences-operation-failed-status-label-value="<%= t("rails_table_preferences.editor.operation_failed_status", default: "設定の操作を完了できませんでした。") %>"
     class="rails-table-preferences-editor">
  <div class="rails-table-preferences-editor__title"><%= title %></div>

  <div class="rails-table-preferences-editor__preset">
    <label for="<%= preset_select_id %>"><%= t("rails_table_preferences.editor.preset_select", default: "保存済み設定") %></label>
    <select id="<%= preset_select_id %>"
            data-rails-table-preferences-target="presetSelect"
            data-action="rails-table-preferences#selectPreset"
            title="<%= preset_target_context %>"
            aria-describedby="<%= preset_hint_id %>">
      <option value="<%= name %>"><%= "#{name} [#{preset_scope_owner_label}]" %></option>
    </select>

    <label for="<%= preset_name_id %>"><%= t("rails_table_preferences.editor.preset", default: "設定名") %></label>
    <input type="text"
           id="<%= preset_name_id %>"
           value="<%= name %>"
           title="<%= preset_name_context %>"
           aria-describedby="<%= preset_hint_id %>"
           data-rails-table-preferences-target="presetName">

    <label class="rails-table-preferences-editor__default-preset">
      <input type="checkbox"
             data-rails-table-preferences-target="defaultPreset"
             aria-describedby="<%= default_preset_hint_id %>">
      <%= t("rails_table_preferences.editor.default_preset", default: "標準設定にする") %>
    </label>
  </div>

  <p id="<%= preset_hint_id %>" class="rails-table-preferences-editor__hint"><%= preset_relationship_hint %></p>
  <p id="<%= default_preset_hint_id %>" class="rails-table-preferences-editor__hint"><%= default_preset_hint %></p>

  <p class="rails-table-preferences-editor__hint"
     data-rails-table-preferences-target="readOnlyHint"
     hidden><%= read_only_preset_hint %></p>

  <div data-rails-table-preferences-target="editorRows" class="rails-table-preferences-editor__rows"></div>
  <div class="rails-table-preferences-editor__status"
       data-rails-table-preferences-target="status"
       role="status"
       aria-live="polite"
       aria-atomic="true"
       aria-label="<%= status_region_label %>"></div>

  <p id="<%= action_hint_id %>" class="rails-table-preferences-editor__hint"><%= action_hint %></p>

  <div class="rails-table-preferences-editor__actions">
    <button type="button"
            data-action="rails-table-preferences#applyFromEditor"
            title="<%= apply_context %>"
            aria-label="<%= "#{t("rails_table_preferences.editor.apply", default: "適用")}: #{apply_context}" %>"
            aria-describedby="<%= action_hint_id %>"><%= t("rails_table_preferences.editor.apply", default: "適用") %></button>
    <button type="button"
            data-action="rails-table-preferences#saveFromEditor"
            title="<%= save_context %>"
            aria-label="<%= "#{t("rails_table_preferences.editor.save", default: "保存")}: #{save_context}" %>"
            aria-describedby="<%= action_hint_id %>"><%= t("rails_table_preferences.editor.save", default: "保存") %></button>
    <button type="button"
            data-action="rails-table-preferences#createPresetFromEditor"
            title="<%= save_as_new_context %>"
            aria-label="<%= "#{t("rails_table_preferences.editor.save_as_new", default: "別名で保存")}: #{save_as_new_context}" %>"
            aria-describedby="<%= action_hint_id %>"><%= t("rails_table_preferences.editor.save_as_new", default: "別名で保存") %></button>
    <button type="button"
            data-action="rails-table-preferences#deletePreset"
            title="<%= delete_confirm_label %>"
            aria-label="<%= "#{delete_label}: #{delete_confirm_label}" %>"><%= delete_label %></button>
    <button type="button"
            data-action="rails-table-preferences#resetEditor"
            title="<%= reset_hint %>"
            aria-label="<%= reset_hint %>"><%= reset_label %></button>
  </div>
</div>
