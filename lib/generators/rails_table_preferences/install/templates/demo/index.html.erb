<%= table_preferences_editor(
  table_key: :rails_table_preferences_demo_orders,
  settings: @table_preference_settings,
  columns: @table_columns,
  title: "デモ受注一覧の表示設定"
) %>

<% demo_hidden_fields_html = table_preferences_hidden_fields(
  settings: @table_preference_settings,
  columns: @table_columns
) %>

<%= form_with url: request.path, method: :get do %>
  <%= text_field_tag :search_word, params[:search_word], placeholder: "得意先名" %>

  <%= demo_hidden_fields_html %>

  <%= submit_tag "検索" %>
<% end %>

<details class="rails-table-preferences-demo-summary rails-table-preferences-demo-support-details">
  <summary>検索フォーム hidden fields プレビュー</summary>

  <p>
    上の検索フォームが、現在保存されている filter / sort 状態から送信する
    hidden input を確認するためのプレビューです。下の export payload
    プレビューとは別の検証面です。
  </p>

  <% demo_hidden_fields_preview = demo_hidden_fields_html.present? ? String.new(demo_hidden_fields_html.to_s) : "保存済みの filter / sort hidden fields は現在生成されていません。" %>
  <div class="rails-table-preferences-demo-copy-controls">
    <h3 id="rails-table-preferences-demo-hidden-fields-copy-heading">hidden fields 証跡</h3>
    <button type="button"
            class="rails-table-preferences-demo-copy-trigger"
            data-rails-table-preferences-demo-copy-trigger
            data-rails-table-preferences-demo-copy-source="hidden-fields"
            data-rails-table-preferences-demo-copy-target="rails-table-preferences-demo-hidden-fields-preview"
            aria-describedby="rails-table-preferences-demo-hidden-fields-copy-status">
      hidden fields プレビューをコピー
    </button>
    <span class="rails-table-preferences-demo-copy-status"
          id="rails-table-preferences-demo-hidden-fields-copy-status"
          role="status"
          aria-live="polite"
          data-rails-table-preferences-demo-copy-status
          data-rails-table-preferences-demo-copy-source="hidden-fields"></span>
  </div>

  <pre class="rails-table-preferences-demo-hidden-fields-preview" id="rails-table-preferences-demo-hidden-fields-preview"><code><%= h(demo_hidden_fields_preview) %></code></pre>

