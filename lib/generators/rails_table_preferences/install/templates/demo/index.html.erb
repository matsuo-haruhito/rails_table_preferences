          <dd><%= @demo_owner_summary.fetch("identifier") %></dd>
        </div>
      </dl>
    </div>

    <div class="rails-table-preferences-demo-verification-panel">
      <h3>owner 切り替え</h3>

      <p>
        demo-only のリンクで active owner を切り替え、代表 owner 間で保存済み
        preset が分離されることを確認します。
      </p>

      <% if @demo_owner_switch_ready %>
        <ul class="rails-table-preferences-demo-owner-switches">
          <% @demo_owner_switches.each do |switch| %>
            <li>
              <%= link_to switch.fetch("label"),
                          switch.fetch("path"),
                          class: [
                            "rails-table-preferences-demo-owner-switch",
                            ("rails-table-preferences-demo-owner-switch--active" if switch["active"])
                          ].compact.join(" "),
                          "aria-current": ("page" if switch["active"]) %>
              <span><%= switch.fetch("description") %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="rails-table-preferences-demo-owner-note">
          save / load の分離をここで比較するには、host app owner を維持したまま
          owner record をもう 1 件以上作成してください。
        </p>
      <% end %>
    </div>

    <div class="rails-table-preferences-demo-verification-panel">
      <h3>現在の scope context</h3>

      <p>
        <strong>現在の context:</strong>
        <% if @demo_scope_context_summary["owner_only"] %>
          owner-only
        <% else %>
          <% summary_parts = [] %>
          <% if @demo_scope_context_summary.fetch("roles", []).any? %>
            <% summary_parts << "roles: [#{@demo_scope_context_summary.fetch("roles").join(", ")}]" %>
          <% end %>
          <% if @demo_scope_context_summary["organization"].present? %>
            <% summary_parts << "organization: #{@demo_scope_context_summary["organization"]}" %>
          <% end %>
