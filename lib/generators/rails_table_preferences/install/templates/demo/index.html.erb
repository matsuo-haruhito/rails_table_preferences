                          "rails-table-preferences-demo-scope-switch",
                          ("rails-table-preferences-demo-scope-switch--active" if switch["active"])
                        ].compact.join(" "),
                        "aria-current": ("page" if switch["active"]) %>
            <span><%= switch.fetch("description") %></span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
