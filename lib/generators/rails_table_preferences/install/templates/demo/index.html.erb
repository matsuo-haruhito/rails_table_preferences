<script<%= respond_to?(:content_security_policy_nonce) && content_security_policy_nonce.present? ? tag.attributes(nonce: content_security_policy_nonce) : nil %>>
  (() => {
    if (!window.__railsTablePreferencesDemoCopyInstalled) {
      window.__railsTablePreferencesDemoCopyInstalled = true

      const copyTriggers = () => document.querySelectorAll("[data-rails-table-preferences-demo-copy-trigger]")
      const copyStatusesFor = (source) => document.querySelectorAll(`[data-rails-table-preferences-demo-copy-status][data-rails-table-preferences-demo-copy-source="${source}"]`)
      const copyAvailable = () => Boolean(navigator.clipboard?.writeText)
      const copyTargetText = (target) => target?.innerText?.trim() || target?.textContent?.trim() || ""
      const setCopyStatus = (source, message) => {
        copyStatusesFor(source).forEach((element) => { element.textContent = message })
      }
      const updateCopyAvailability = () => {
        copyTriggers().forEach((trigger) => {
          const available = copyAvailable()
          trigger.disabled = !available
          if (!available) {
            setCopyStatus(trigger.dataset.railsTablePreferencesDemoCopySource, "このブラウザではコピーできません。プレビュー本文を選択してください。")
          }
        })
      }

      updateCopyAvailability()

      document.addEventListener("click", async (event) => {
        const trigger = event.target.closest("[data-rails-table-preferences-demo-copy-trigger]")
        if (!trigger) return

        event.preventDefault()

        const source = trigger.dataset.railsTablePreferencesDemoCopySource
        const target = document.getElementById(trigger.dataset.railsTablePreferencesDemoCopyTarget)
        const text = copyTargetText(target)

        if (!copyAvailable()) {
          trigger.disabled = true
          setCopyStatus(source, "このブラウザではコピーできません。プレビュー本文を選択してください。")
          return
        }

        if (!text) {
          setCopyStatus(source, "コピーできる内容はまだありません。")
          return
        }

        try {
          await navigator.clipboard.writeText(text)
          setCopyStatus(source, "プレビュー本文をコピーしました。")
        } catch (error) {
          setCopyStatus(source, "コピーに失敗しました。プレビュー本文を選択してください。")
          console.error(error)
        }
      })
    }

    if (!window.__railsTablePreferencesDemoResetInstalled) {
      window.__railsTablePreferencesDemoResetInstalled = true

      const resetStatusElements = () => document.querySelectorAll("[data-rails-table-preferences-demo-reset-status]")
      const setDemoResetStatus = (message) => {
        resetStatusElements().forEach((element) => { element.textContent = message })
      }
      const csrfToken = () => document.querySelector("meta[name='csrf-token']")?.content || ""
      const demoControllerElement = () => document.querySelector("[data-controller~='rails-table-preferences']")
      const collectionUrl = () => demoControllerElement()?.dataset.railsTablePreferencesCollectionUrlValue
      const preferenceUrl = (url, name) => `${url}/${encodeURIComponent(name || "default")}`
      const ownerPreferences = (preferences) => preferences.filter((preference) => (
        preference.editable && (preference.scope_type || "owner") === "owner"
      ))

      document.addEventListener("click", async (event) => {
        const trigger = event.target.closest("[data-rails-table-preferences-demo-reset-trigger]")
        if (!trigger) return

        event.preventDefault()
        if (trigger.disabled) return

        const url = collectionUrl()
        if (!url) {
          setDemoResetStatus("preset editor が表示されるまで、デモ状態リセットは利用できません。")
          return
        }

        trigger.disabled = true
        setDemoResetStatus("この demo table の owner preset をリセットしています...")

        try {
          const response = await fetch(url, { headers: { "Accept": "application/json" } })
          if (!response.ok) throw new Error(`Failed to load table preference presets: ${response.status}`)
          const payload = await response.json()
          const preferences = ownerPreferences(payload.preferences || [])

          await Promise.all(preferences.map((preference) => fetch(preferenceUrl(url, preference.name), {
            method: "DELETE",
            headers: { "Accept": "application/json", "X-CSRF-Token": csrfToken() }
          }).then((deleteResponse) => {
            if (!deleteResponse.ok && deleteResponse.status !== 204) {
              throw new Error(`Failed to delete table preference preset: ${deleteResponse.status}`)
            }
          })))

          setDemoResetStatus("owner preset をリセットしました。seeded baseline を再読み込みしています...")
          window.location.reload()
        } catch (error) {
          trigger.disabled = false
          setDemoResetStatus("デモ状態リセットを完了できませんでした。browser console または server log を確認してから再試行してください。")
          console.error(error)
        }
      })
    }

    if (window.__railsTablePreferencesDemoFailureInstalled) return
    window.__railsTablePreferencesDemoFailureInstalled = true

    const nativeFetch = window.fetch.bind(window)
    let failNextPresetRequest = false

    const statusElements = () => document.querySelectorAll("[data-rails-table-preferences-demo-failure-status]")
    const setDemoFailureStatus = (message) => {
      statusElements().forEach((element) => { element.textContent = message })
    }
    const preferenceUrls = () => Array.from(document.querySelectorAll("[data-controller~='rails-table-preferences']")).flatMap((element) => [
      element.dataset.railsTablePreferencesCollectionUrlValue,
      element.dataset.railsTablePreferencesUrlValue
    ].filter(Boolean))
    const requestUrl = (input) => typeof input === "string" ? input : input?.url || ""
    const matchesPreferenceRequest = (input) => {
      const url = requestUrl(input)
      return preferenceUrls().some((preferenceUrl) => (
        url === preferenceUrl ||
        url.startsWith(`${preferenceUrl}/`) ||
        url.startsWith(`${preferenceUrl}?`)
      ))
    }

    document.addEventListener("click", (event) => {
      const trigger = event.target.closest("[data-rails-table-preferences-demo-failure-trigger]")
      if (!trigger) return

      failNextPresetRequest = true
      setDemoFailureStatus("次の preset request は1回だけ失敗します。")
    })

    window.fetch = (...args) => {
      if (failNextPresetRequest && matchesPreferenceRequest(args[0])) {
        failNextPresetRequest = false
        setDemoFailureStatus("preset request を予定どおり1回失敗させました。同じ操作を retry して復帰を確認してください。")
        return Promise.resolve(new Response(JSON.stringify({ error: "Demo failure" }), {
          status: 503,
          headers: { "Content-Type": "application/json" }
        }))
      }

      return nativeFetch(...args)
    }
  })()
</script>